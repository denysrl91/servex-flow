# Public values only. Never commit real secrets.
# Lovable Cloud manages the real .env at runtime; this file is documentation.

VITE_SUPABASE_URL=your_lovable_cloud_or_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_public_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_ref

# Server-only secrets (configured in Lovable Cloud → Secrets, NEVER in code):
# SUPABASE_SERVICE_ROLE_KEY=
# LOVABLE_API_KEY=
